# ============================================================
# Discute avec ton Président — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ============================================================

# Supabase (base de données + FTS)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mistral AI (LLM principal, gratuit) — https://console.mistral.ai
MISTRAL_API_KEY=

# Google Gemini (fallback LLM) — https://aistudio.google.com
GOOGLE_AI_API_KEY=

# ElevenLabs TTS (optionnel — voix Macron) — https://elevenlabs.io
# Laisser vide pour utiliser la voix navigateur (Web Speech API)
ELEVENLABS_API_KEY=
# Voice ID optionnel — si vide, recherche auto d'une voix Macron dans la bibliothèque
ELEVENLABS_VOICE_ID=

# Serveur API
PORT=3001
ALLOWED_ORIGIN=http://localhost:4000

# Frontend Vite (app/)
VITE_PRESIDENT_API_URL=http://localhost:3001
